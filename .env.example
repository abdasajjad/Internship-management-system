PORT=5000
MONGO_URI=mongodb://admin:password@localhost:27017/internship_db?authSource=admin
JWT_SECRET=change_me_to_a_long_random_secret
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Email Configuration (for forgot password feature)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Frontend URL (used for password reset links)
FRONTEND_URL=http://localhost:5173

# Optional: one-time admin seed values (used by `npm run seed:admin`)
ADMIN_SEED_NAME=Rishal
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=Rishalsh@786
